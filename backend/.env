# 服务端口
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=enterprise_ad_system

# JWT
JWT_SECRET=your_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# 文件上传路径
UPLOAD_DIR=uploads
MAX_FILE_SIZE=50mb

# 环境
NODE_ENV=development

# 前端地址（CORS）
FRONTEND_ORIGIN=http://localhost:5173
