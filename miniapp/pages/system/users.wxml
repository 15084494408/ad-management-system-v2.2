<view class="page-container">
  <view class="search-bar">
    <t-search placeholder="搜索用户名/姓名" value="{{keyword}}" bind:change="onSearch" bind:submit="doSearch" shape="round" />
  </view>

  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx 0">
    <t-loading loading theme="circular" size="40rpx" />
  </view>
  <view wx:elif="{{users.length === 0}}" class="empty-state">
    <t-icon name="user" size="96rpx" color="#ddd" />
    <text class="empty-text">暂无用户</text>
  </view>

  <view class="user-list" wx:else>
    <view class="user-card card" wx:for="{{users}}" wx:key="id">
      <view class="user-header">
        <view class="user-avatar" style="background:{{item.status === 1 ? 'linear-gradient(135deg,#00d4ff,#764ba2)' : '#ccc'}}">
          {{item.realName ? item.realName[0] : (item.username ? item.username[0] : '?')}}
        </view>
        <view class="user-info">
          <view class="user-name-row">
            <text class="user-name">{{item.realName || item.username}}</text>
            <t-tag size="small" variant="light" theme="{{item.status === 1 ? 'success' : 'default'}}">{{item.statusLabel}}</t-tag>
          </view>
          <text class="user-meta">{{item.username}}</text>
          <text class="user-meta">{{item.roleNames}}</text>
        </view>
      </view>
      <view class="user-actions">
        <t-button size="small" variant="outline" theme="{{item.status === 1 ? 'warning' : 'success'}}" data-user="{{item}}" bindtap="toggleStatus">{{item.status === 1 ? '禁用' : '启用'}}</t-button>
        <t-button size="small" variant="outline" data-user="{{item}}" bindtap="resetPassword">重置密码</t-button>
        <t-button size="small" variant="outline" theme="danger" data-user="{{item}}" bindtap="deleteUser">删除</t-button>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{users.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{noMore}}">没有更多了</text>
  </view>

  <t-fab icon="add" bind:click="showCreateDialog" class="fab-btn" />
</view>
