<view class="page-container">
  <view class="card">
    <view class="section-title">用户信息</view>
    <t-input label="用户名" placeholder="请输入" value="{{form.username}}" bind:change="onChange" data-field="username" maxlength="30" />
    <t-input label="密码" placeholder="请输入" type="password" value="{{form.password}}" bind:change="onChange" data-field="password" />
    <t-input label="姓名" placeholder="请输入" value="{{form.realName}}" bind:change="onChange" data-field="realName" maxlength="20" />
    <t-input label="手机号" placeholder="选填" type="number" value="{{form.phone}}" bind:change="onChange" data-field="phone" maxlength="11" />
    <t-input label="邮箱" placeholder="选填" value="{{form.email}}" bind:change="onChange" data-field="email" maxlength="50" />
  </view>
  <view class="submit-area safe-bottom">
    <t-button theme="primary" block size="large" loading="{{submitting}}" bindtap="submit">创建用户</t-button>
  </view>
</view>
