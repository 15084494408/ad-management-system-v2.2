<view class="page">

  <!-- 顶部操作栏 -->
  <view class="header-bar">
    <text class="header-title">系统消息（{{unreadCount}}条未读）</text>
    <t-button size="small" variant="outline" bindtap="markAllRead" wx:if="{{unreadCount > 0}}">全部已读</t-button>
  </view>

  <!-- 内容区域 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card" wx:for="{{5}}" wx:key="*this" style="margin:16rpx 24rpx;height:120rpx"></view>
  </block>

  <block wx:elif="{{list.length === 0}}">
    <view class="empty-state">
      <t-icon name="notification" size="96rpx" color="#ddd" />
      <text class="empty-text">暂无消息</text>
    </view>
  </block>

  <block wx:else>
    <view wx:for="{{list}}" wx:key="id" class="msg-card {{item.read ? 'msg-read' : ''}}" bindtap="markAsRead" data-id="{{item.id}}">
      <view class="msg-unread-dot" wx:if="{{!item.read}}"></view>
      <view class="msg-icon">
        <t-icon name="{{item.type === 1 ? 'notification' : item.type === 2 ? 'warning' : 'info-circle'}}" size="36rpx" color="{{item.read ? '#bbb' : '#00a8cc'}}" />
      </view>
      <view class="msg-content">
        <text class="msg-title">{{item.title}}</text>
        <text class="msg-desc" wx:if="{{item.content}}">{{item.content}}</text>
        <text class="msg-time">{{item.createTime}}</text>
      </view>
      <t-icon name="chevron-right" size="28rpx" color="#ddd" />
    </view>
  </block>
</view>
