<view class="page-container">
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" space-evenly>
    <t-tab-panel label="待办事项" value="todo" />
    <t-tab-panel label="系统公告" value="notice" />
  </t-tabs>

  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx 0">
    <t-loading loading theme="circular" size="40rpx" />
  </view>

  <!-- 待办列表 -->
  <block wx:if="{{activeTab === 'todo'}}">
    <view class="tip-bar" wx:if="{{todos.length > 0}}">
      <t-icon name="info-circle" size="28rpx" color="#667eea" />
      <text style="font-size:24rpx;color:#667eea;margin-left:8rpx">点击待办可标记为已完成</text>
    </view>
    <view class="todo-item" wx:for="{{todos}}" wx:key="id" data-id="{{item.id}}" bindtap="toggleTodo">
      <view class="todo-left">
        <view class="todo-priority {{item.priority >= 2 ? 'urgent' : ''}}"></view>
        <view class="todo-info">
          <text class="todo-title">{{item.title}}</text>
          <text class="todo-meta" wx:if="{{item.customerName}}">{{item.customerName}} · {{item.contactPhone || ''}}</text>
        </view>
      </view>
      <text class="todo-time">{{item.createTime}}</text>
    </view>
    <view wx:if="{{!loading && todos.length === 0}}" style="text-align:center;padding:100rpx 0;color:#999;font-size:26rpx">暂无待办事项</view>
  </block>

  <!-- 公告列表 -->
  <block wx:if="{{activeTab === 'notice'}}">
    <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="readNotice" data-item="{{item}}">
      <view class="notice-dot"></view>
      <view class="notice-info">
        <text class="notice-title">{{item.title}}</text>
        <text class="notice-time">{{item.createTime}}</text>
      </view>
      <t-icon name="chevron-right" size="28rpx" color="#ccc" />
    </view>
    <view wx:if="{{!loading && notices.length === 0}}" style="text-align:center;padding:100rpx 0;color:#999;font-size:26rpx">暂无公告</view>
  </block>
</view>
