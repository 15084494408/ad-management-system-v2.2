.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 顶部操作栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  background: #f5f7fa;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary, #666);
}

/* 消息卡片 */
.msg-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 24rpx 12rpx;
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
  position: relative;
  transition: opacity 0.2s;
}

.msg-card:active {
  opacity: 0.85;
  background: #f9f9f9;
}

.msg-read {
  opacity: 0.65;
}

/* 未读红点 */
.msg-unread-dot {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--danger, #ef4444);
}

/* 图标 */
.msg-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #f0f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 内容 */
.msg-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.msg-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary, #333);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-read .msg-title {
  color: var(--text-hint, #999);
}

.msg-desc {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.msg-time {
  font-size: 22rpx;
  color: var(--text-hint, #ccc);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  gap: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint, #999);
}
