.todo-list { margin-top: 16rpx; }

.todo-card { padding: 24rpx; }

.todo-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.todo-left {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex: 1;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
}
.priority-1 { background: #ccc; }
.priority-2 { background: #faad14; }
.priority-3 { background: #E34D59; }

.todo-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
}

.todo-body {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 16rpx 0 0 28rpx;
}

.todo-meta {
  font-size: 24rpx;
  color: #888;
  background: #f5f7fa;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.todo-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.todo-time {
  font-size: 22rpx;
  color: #bbb;
}

.todo-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.action-btn.complete { color: #0F6E56; }
.action-btn.more { color: #0052D9; }
.action-btn.delete { color: #E34D59; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.empty-text { font-size: 28rpx; color: #999; }

/* 弹窗 */
.popup-content { padding: 32rpx; }
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.popup-title { font-size: 32rpx; font-weight: 600; }

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 0;
}
.form-label { font-size: 28rpx; color: #333; font-weight: 500; }

.fab-btn { position: fixed; right: 40rpx; bottom: 120rpx; z-index: 99; }
