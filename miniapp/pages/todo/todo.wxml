<view class="page-container">
  <!-- 状态Tab -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" space-evenly>
    <t-tab-panel label="全部" value="all" />
    <t-tab-panel label="处理中" value="pending" />
    <t-tab-panel label="已完成" value="done" />
  </t-tabs>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx 0">
    <t-loading loading theme="circular" size="40rpx" />
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{todos.length === 0}}" class="empty-state">
    <t-icon name="todo-list" size="96rpx" color="#ddd" />
    <text class="empty-text">暂无待办事项</text>
  </view>

  <!-- 待办列表 -->
  <view class="todo-list" wx:else>
    <view class="todo-card card" wx:for="{{todos}}" wx:key="id">
      <view class="todo-header">
        <view class="todo-left">
          <view class="priority-dot priority-{{item.priority || 1}}"></view>
          <text class="todo-title">{{item.requirements || '待办事项'}}</text>
        </view>
        <t-tag size="small" variant="light" theme="{{item.status >= 3 ? 'success' : item.status >= 2 ? 'primary' : 'warning'}}">{{item.statusLabel}}</t-tag>
      </view>

      <view class="todo-body" wx:if="{{item.customerName || item.contactPhone || item.source}}">
        <text class="todo-meta" wx:if="{{item.customerName}}">{{item.customerName}}</text>
        <text class="todo-meta" wx:if="{{item.contactPhone}}">{{item.contactPhone}}</text>
        <text class="todo-meta" wx:if="{{item.source}}">{{item.source}}</text>
      </view>

      <view class="todo-footer">
        <text class="todo-time">{{item.createTime}}</text>
        <view class="todo-actions">
          <text class="action-btn complete" wx:if="{{item.status < 4}}" data-id="{{item.id}}" data-status="4" data-label="已转订单" bindtap="updateStatus">完成</text>
          <text class="action-btn more" wx:if="{{item.status < 3}}" data-id="{{item.id}}" bindtap="updateStatus">推进</text>
          <text class="action-btn delete" data-id="{{item.id}}" bindtap="deleteTodo">删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 浮动新增 -->
  <t-fab icon="add" bind:click="showCreateDialog" class="fab-btn" />

  <!-- 新建待办弹窗 -->
  <t-popup visible="{{showCreate}}" placement="bottom" bind:close="hideCreateDialog">
    <view class="popup-content safe-bottom">
      <view class="popup-header">
        <text class="popup-title">新建待办</text>
        <t-icon name="close" size="40rpx" color="#999" bindtap="hideCreateDialog" />
      </view>
      <t-textarea label="需求描述" placeholder="请输入需求描述" value="{{newTodo.requirements}}" maxlength="500" bind:change="onNewFieldChange" data-field="requirements" />
      <t-input label="客户名称" placeholder="选填" value="{{newTodo.customerName}}" bind:change="onNewFieldChange" data-field="customerName" />
      <t-input label="联系电话" placeholder="选填" type="number" value="{{newTodo.contactPhone}}" bind:change="onNewFieldChange" data-field="contactPhone" />
      <t-input label="来源" placeholder="选填，如电话/微信/到店" value="{{newTodo.source}}" bind:change="onNewFieldChange" data-field="source" />
      <view class="form-group">
        <text class="form-label">优先级</text>
        <t-radio-group value="{{newTodo.priority}}" bind:change="onPriorityChange">
          <t-radio value="1" label="普通" />
          <t-radio value="2" label="紧急" />
          <t-radio value="3" label="非常紧急" />
        </t-radio-group>
      </view>
      <t-button theme="primary" block size="large" bindtap="createTodo" style="margin-top:24rpx">创建待办</t-button>
    </view>
  </t-popup>
</view>
