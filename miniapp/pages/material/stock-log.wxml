<view class="page-container">
  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx 0">
    <t-loading loading theme="circular" size="40rpx" />
  </view>
  <view wx:elif="{{logs.length === 0}}" class="empty-state">
    <t-icon name="file" size="96rpx" color="#ddd" />
    <text class="empty-text">暂无库存记录</text>
  </view>

  <view class="log-list" wx:else>
    <view class="log-card card" wx:for="{{logs}}" wx:key="id">
      <view class="log-header">
        <view class="log-left">
          <t-tag size="small" variant="light" theme="{{item.isIncome ? 'success' : 'danger'}}">{{item.typeLabel}}</t-tag>
          <text class="log-material">{{item.materialName || '物料'}}</text>
        </view>
        <text class="log-quantity {{item.isIncome ? 'income' : 'expense'}}">{{item.quantityStr}}</text>
      </view>
      <view class="log-body" wx:if="{{item.orderNo || item.remark}}">
        <text class="log-meta" wx:if="{{item.orderNo}}">关联订单: {{item.orderNo}}</text>
        <text class="log-meta" wx:if="{{item.remark}}">{{item.remark}}</text>
      </view>
      <view class="log-footer">
        <text class="log-time">{{item.createTime}}</text>
        <text class="log-operator" wx:if="{{item.operatorName}}">{{item.operatorName}}</text>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{logs.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{noMore}}">没有更多了</text>
  </view>
</view>
