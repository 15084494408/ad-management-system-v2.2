.category-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}
.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #888;
  background: #f5f7fa;
  border-radius: 24rpx;
  margin-right: 12rpx;
  border: 1rpx solid #f0f0f0;
}
.category-tag.active {
  background: #e6f7fa;
  color: #00a8cc;
  border-color: #b0dde6;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 20rpx;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #00a8cc;
  padding: 8rpx 16rpx;
}

.material-card { padding: 24rpx; }
.material-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.material-name { font-size: 30rpx; font-weight: 600; color: #1a1a2e; }
.material-tags { display: flex; gap: 8rpx; }

.material-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.info-label { font-size: 22rpx; color: #aaa; }
.info-value { font-size: 26rpx; color: #555; font-weight: 500; }
.info-value.warning { color: #ef4444; }

.material-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}
.material-time { font-size: 22rpx; color: #bbb; }

.footer-actions {
  display: flex;
  gap: 16rpx;
}
.icon-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.empty-text { font-size: 28rpx; color: #ddd; }
.load-more { text-align: center; padding: 32rpx; font-size: 24rpx; color: #ddd; }
