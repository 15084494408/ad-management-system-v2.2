<view class="page-container">
  <view class="card">
    <view class="section-title">物料信息</view>
    <t-input label="名称" placeholder="请输入物料名称" value="{{form.name}}" bind:change="onChange" data-field="name" maxlength="50" />
    <t-cell title="分类" arrow hover value="{{form.categoryId ? '已选择' : '请选择'}}" bindtap="pickCategory" />
    <t-input label="单位" placeholder="如：个/张/米/平方米" value="{{form.unit}}" bind:change="onChange" data-field="unit" />
    <view class="form-group">
      <text class="form-label">计价方式</text>
      <t-radio-group value="{{form.pricingType}}" bind:change="onPricingTypeChange">
        <t-radio value="0" label="按数量" />
        <t-radio value="1" label="按面积" />
      </t-radio-group>
    </view>
  </view>

  <view class="card">
    <view class="section-title">价格与库存</view>
    <t-input label="单价(元)" placeholder="0" type="digit" value="{{form.unitPrice}}" bind:change="onChange" data-field="unitPrice" />
    <t-input label="成本(元)" placeholder="0" type="digit" value="{{form.unitCost}}" bind:change="onChange" data-field="unitCost" />
    <view class="form-group">
      <text class="form-label">库存管理</text>
      <view class="no-stock-row">
        <text class="ns-label">不计库存（如纸张等消耗品）</text>
        <t-switch value="{{form.noStock === 1}}" bind:change="onNoStockChange" />
      </view>
    </view>
    <view wx:if="{{form.noStock !== 1}}">
      <t-input label="初始库存" placeholder="0" type="number" value="{{form.stock}}" bind:change="onChange" data-field="stock" />
      <t-input label="预警库存" placeholder="低于此数量预警" type="number" value="{{form.warningStock}}" bind:change="onChange" data-field="warningStock" />
    </view>
  </view>

  <view class="card">
    <t-textarea label="备注" placeholder="选填" value="{{form.remark}}" bind:change="onChange" data-field="remark" maxlength="200" />
  </view>

  <view class="submit-area safe-bottom">
    <t-button theme="primary" block size="large" loading="{{submitting}}" bindtap="submit">保存</t-button>
  </view>
</view>

<t-dialog id="t-dialog" />
