.page-container {
  min-height: 100vh;
  background: var(--bg-card, #f0f4f8);
  padding-bottom: 40rpx;
}

/* 顶部用户卡片 */
.profile-header {
  background: linear-gradient(135deg, #00a8cc 0%, #0077b6 100%);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}
.profile-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.profile-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.15);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

/* 分组标题 */
.card-section-title {
  font-size: 24rpx;
  color: var(--text-hint, #999);
  padding: 20rpx 32rpx 8rpx;
  font-weight: 500;
}

/* 菜单卡片 */
.menu-card {
  margin: 16rpx 24rpx 0;
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  overflow: hidden;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color, #f5f5f5);
}
/* :last-child 在 WXSS 中不支持，底部边框保留 */
.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.menu-text {
  font-size: 30rpx;
  color: var(--text-primary, #333);
}
.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.menu-desc {
  font-size: 26rpx;
  color: var(--text-hint, #999);
}

/* 退出按钮 */
.logout-btn {
  margin: 48rpx 24rpx 0;
}
