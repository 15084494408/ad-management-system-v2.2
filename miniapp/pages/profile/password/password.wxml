<view class="page-container">
  <view class="card" style="margin-top:40rpx">
    <view class="section-title">修改密码</view>
    <t-input label="当前密码" type="password" placeholder="请输入当前密码" value="{{oldPassword}}" bind:change="onFieldChange" data-field="oldPassword" />
    <t-input label="新密码" type="password" placeholder="请输入新密码（至少6位）" value="{{newPassword}}" bind:change="onFieldChange" data-field="newPassword" />
    <t-input label="确认密码" type="password" placeholder="请再次输入新密码" value="{{confirmPassword}}" bind:change="onFieldChange" data-field="confirmPassword" />
    <view style="margin-top:40rpx">
      <t-button block theme="primary" size="large" bindtap="submit" loading="{{submitting}}">确认修改</t-button>
    </view>
  </view>
</view>
