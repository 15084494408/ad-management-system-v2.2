.page-container {
  padding: 24rpx;
  padding-bottom: 140rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* ====== 状态横幅 ====== */
.status-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.status-banner-1 { background: linear-gradient(135deg, #f59e0b, #d97706); }
.status-banner-2 { background: linear-gradient(135deg, var(--primary), #0077b6); }
.status-banner-3 { background: linear-gradient(135deg, #10b981, #059669); }
.status-banner-4 { background: linear-gradient(135deg, #9ca3af, #6b7280); }

.status-banner-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-banner-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.status-banner-title {
  font-size: 32rpx;
  font-weight: 600;
}

.status-banner-desc {
  font-size: 24rpx;
  opacity: 0.85;
}

/* ====== 卡片通用 ====== */
.card {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

/* ====== 信息行 ====== */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: var(--text-secondary, #666);
  flex-shrink: 0;
}

.info-value {
  color: var(--text-primary, #333);
  text-align: right;
  word-break: break-all;
  max-width: 60%;
}

/* ====== 物料卡片 ====== */
.material-card {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.material-name {
  width: 100%;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary, #333);
}

.material-meta {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
  color: var(--text-hint, #999);
  flex: 1;
}

.material-price {
  font-size: 24rpx;
  color: var(--primary, #00a8cc);
  font-weight: 500;
}

.material-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  margin-top: 8rpx;
  border-top: 1rpx solid var(--border-color, #f0f0f0);
  font-size: 28rpx;
  font-weight: 600;
}

/* ====== 备注 ====== */
.remark-content {
  font-size: 26rpx;
  color: var(--text-secondary, #666);
  line-height: 1.6;
  padding: 8rpx 0;
}

/* ====== 底部操作栏 ====== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card, #fff);
  padding: 16rpx 24rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.action-bar > t-button {
  flex: 1;
}
