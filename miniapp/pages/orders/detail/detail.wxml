<view class="page-container">

  <!-- 顶部状态横幅 -->
  <view class="status-banner status-banner-{{paymentStatus}}">
    <view class="status-banner-icon">
      <t-icon name="{{paymentStatusIcon}}" size="48rpx" color="#fff" />
    </view>
    <view class="status-banner-text">
      <text class="status-banner-title">{{paymentStatusText}}</text>
      <text class="status-banner-desc">{{paymentStatusDesc}}</text>
    </view>
  </view>

  <!-- 基本信息卡片 -->
  <view class="card">
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{detail.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">客户名称</text>
      <text class="info-value">{{detail.customerName || '散客'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">创建时间</text>
      <text class="info-value">{{detail.createTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">更新时间</text>
      <text class="info-value">{{detail.updateTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">订单状态</text>
      <view class="status-dot status-{{detail.status}}">{{detail.statusText}}</view>
    </view>
  </view>

  <!-- 金额信息卡片 -->
  <view class="card">
    <view class="section-title">金额信息</view>
    <view class="info-row">
      <text class="info-label">订单金额</text>
      <text class="info-value">¥{{detail.totalAmount}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.discountAmount > 0}}">
      <text class="info-label">优惠金额</text>
      <text class="info-value" style="color:#10b981">-¥{{detail.discountAmount}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.roundingAmount > 0}}">
      <text class="info-label">抹零金额</text>
      <text class="info-value" style="color:#10b981">-¥{{detail.roundingAmount}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.paidAmount > 0}}">
      <text class="info-label">已付金额</text>
      <text class="info-value" style="color:var(--primary)">¥{{detail.paidAmount}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.unpaidAmount > 0}}">
      <text class="info-label">待收金额</text>
      <text class="info-value" style="color:var(--danger, #ef4444);font-weight:700">¥{{detail.unpaidAmount}}</text>
    </view>
  </view>

  <!-- 物料列表卡片 -->
  <view class="card" wx:if="{{detail.materials && detail.materials.length > 0}}">
    <view class="section-title">物料清单</view>
    <view wx:for="{{detail.materials}}" wx:key="id" class="material-card">
      <view class="material-name">{{item.materialName}}</view>
      <view class="material-meta">
        <text>规格: {{item.spec || '-'}}</text>
        <text>数量: {{item.quantity}}</text>
      </view>
      <view class="material-price">{{item.unitPrice}} / {{item.unit || '件'}}</view>
    </view>

    <!-- 合计 -->
    <view class="material-total" wx:if="{{detail.materials.length > 1}}">
      <text>合计</text>
      <text class="amount">¥{{detail.totalAmount || 0}}</text>
    </view>
  </view>

  <!-- 备注卡片 -->
  <view class="card" wx:if="{{detail.remark}}">
    <view class="section-title">备注信息</view>
    <view class="remark-content">{{detail.remark}}</view>
  </view>

  <!-- 底部操作栏固定 -->
  <view class="action-bar" style="padding-bottom: env(safe-area-inset-bottom);">
    <t-button variant="outline" bindtap="editOrder" wx:if="{{detail.status !== 3 && detail.status !== 4}}">编辑</t-button>
    <t-button variant="outline" bindtap="printOrder">打印</t-button>
    <t-button theme="primary" bindtap="recordPayment" wx:if="{{detail.unpaidAmount > 0}}">收款</t-button>
    <t-button variant="outline" bindtap="shareOrder">分享</t-button>
  </view>
</view>
