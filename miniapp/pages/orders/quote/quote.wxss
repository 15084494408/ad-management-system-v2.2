.result { margin-top: 24rpx; }
.result-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #888;
}
.result-row.total {
  font-weight: 600;
  color: #1a1a2e;
  font-size: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  margin-top: 8rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}
.summary-row.total {
  font-size: 36rpx;
  font-weight: 700;
  color: #E34D59;
}

.submit-area { margin-top: 24rpx; }
