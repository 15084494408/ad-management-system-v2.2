<view class="page">
  <!-- 粘性搜索栏 -->
  <view class="search-bar-sticky">
    <view class="search-bar-inner">
      <t-input placeholder="搜索订单号/客户名" value="{{searchValue}}" bind:change="onSearch" bind:enter="doSearch" clearable>
        <t-icon slot="prefixIcon" name="search" size="32rpx" color="#999" />
      </t-input>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs-wrap">
    <t-tabs value="{{activeTab}}" bind:change="onTabChange">
      <t-tab-panel label="全部" value="all" />
      <t-tab-panel label="待处理" value="1" />
      <t-tab-panel label="进行中" value="2" />
      <t-tab-panel label="已完成" value="3" />
      <t-tab-panel label="已取消" value="4" />
    </t-tabs>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" style="margin-top:20rpx">
    <block wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{6}}" wx:key="*this" style="margin-bottom:16rpx;height:180rpx"></view>
    </block>
    <block wx:elif="{{orders.length === 0}}">
      <view class="empty-state">暂无订单数据</view>
    </block>
    <block wx:else>
      <view wx:for="{{orders}}" wx:key="id" class="order-card" bindtap="goDetail" data-id="{{item.id}}" hover-class="order-card-active">
        <!-- 左侧状态色条 -->
        <view class="order-status-bar order-status-{{item.status}}"></view>
        <view class="order-card-body">
          <!-- 顶部：订单号 + 状态标签 -->
          <view class="order-header-row">
            <text class="order-no">{{item.orderNo}}</text>
            <view class="status-dot status-{{item.status}}">{{item.statusText}}</view>
          </view>
          <!-- 客户名 -->
          <view class="order-customer-row">
            <t-icon name="user" size="24rpx" color="#999" />
            <text class="order-customer">{{item.customerName || '散客'}}</text>
          </view>
          <!-- 底部：左侧时间，右侧金额 -->
          <view class="order-footer-row">
            <text class="order-time">{{item.createTime}}</text>
            <view class="order-amount-col">
              <text class="amount">¥{{item.totalAmount}}</text>
              <text class="order-unpaid" wx:if="{{item.unpaidAmount > 0}}">待收 ¥{{item.unpaidAmount}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loadingMore}}" style="text-align:center;padding:20rpx 0">
    <text style="font-size:24rpx;color:var(--text-hint,#bbb)">加载中...</text>
  </view>
  <view wx:elif="{{!loading && orders.length > 0 && noMore}}" style="text-align:center;padding:20rpx 0">
    <text style="font-size:24rpx;color:var(--text-hint,#bbb)">没有更多了</text>
  </view>

  <!-- FAB 创建订单按钮 -->
  <view class="fab-btn" bindtap="createOrder" style="padding-bottom: env(safe-area-inset-bottom);">
    <t-icon name="add" size="40rpx" color="#fff" />
  </view>
</view>
