.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* ====== 粘性搜索栏 ====== */
.search-bar-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f5f7fa;
  padding: 16rpx 24rpx 8rpx;
}

.search-bar-inner {
  background: #fff;
  border-radius: 100rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* ====== Tab 切换 ====== */
.tabs-wrap {
  background: #f5f7fa;
}

/* ====== 订单卡片 ====== */
.order-list {
  padding: 0 24rpx;
}

.order-card {
  display: flex;
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
}

.order-card-active {
  opacity: 0.8;
  background: #f5f7fa;
}

/* 左侧状态色条 */
.order-status-bar {
  width: 6rpx;
  flex-shrink: 0;
}

.order-status-1 { background: #f59e0b; }
.order-status-2 { background: var(--primary, #00a8cc); }
.order-status-3 { background: #10b981; }
.order-status-4 { background: #999; }

/* 卡片内容区 */
.order-card-body {
  flex: 1;
  padding: 20rpx 24rpx;
}

.order-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  font-family: 'Courier New', monospace;
}

.order-customer-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.order-customer {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
}

.order-footer-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.order-time {
  font-size: 22rpx;
  color: var(--text-hint, #bbb);
}

.order-amount-col {
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.amount {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary, #333);
  font-family: 'Courier New', monospace;
}

.order-unpaid {
  font-size: 20rpx;
  color: var(--danger, #ef4444);
}

/* 状态标签复用全局 status-dot */
.status-dot {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-1 { background: #fef3c7; color: #b45309; }
.status-2 { background: #e0f2fe; color: #0369a1; }
.status-3 { background: #d1fae5; color: #047857; }
.status-4 { background: #f3f4f6; color: #6b7280; }

/* ====== FAB 按钮 ====== */
.fab-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary, #00a8cc);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 168, 204, 0.4);
  z-index: 100;
}
