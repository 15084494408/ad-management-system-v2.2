<view class="page-container">
  <t-search placeholder="搜索会员名称/电话" value="{{keyword}}" bind:change="onSearch" bind:submit="doSearch" shape="round" />

  <view wx:if="{{loading}}" style="text-align:center;padding:80rpx 0">
    <t-loading loading theme="circular" size="40rpx" />
  </view>
  <view wx:elif="{{members.length === 0}}" class="empty-state">
    <t-icon name="usergroup" size="96rpx" color="#ddd" />
    <text class="empty-text">暂无会员</text>
  </view>

  <view class="member-list" wx:else>
    <view class="member-card card" wx:for="{{members}}" wx:key="id">
      <view class="member-header">
        <view class="member-avatar" style="background:linear-gradient(135deg,#faad14 0%,#f5222d 100%)">{{item.name ? item.name[0] : '?'}}</view>
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{item.name}}</text>
            <t-tag size="small" variant="light" theme="warning">{{item.levelName}}</t-tag>
          </view>
          <text class="member-phone">{{item.phone || '-'}}</text>
        </view>
      </view>
      <view class="member-stats">
        <view class="stat-item">
          <text class="stat-val">{{item.balance}}</text>
          <text class="stat-lbl">余额</text>
        </view>
        <view class="stat-item">
          <text class="stat-val">{{item.totalRecharge}}</text>
          <text class="stat-lbl">累计充值</text>
        </view>
        <view class="stat-item">
          <text class="stat-val">{{item.totalConsume}}</text>
          <text class="stat-lbl">累计消费</text>
        </view>
      </view>
      <view class="member-actions">
        <t-button size="small" theme="primary" variant="outline" bindtap="goRecharge" data-id="{{item.id}}">充值</t-button>
        <t-button size="small" variant="outline" bindtap="goTransactions" data-id="{{item.id}}" data-name="{{item.name}}">消费记录</t-button>
        <t-button size="small" variant="outline" bindtap="goDetail" data-id="{{item.id}}">详情</t-button>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{members.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{noMore}}">没有更多了</text>
  </view>
</view>
