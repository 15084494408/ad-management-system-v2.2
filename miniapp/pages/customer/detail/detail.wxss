.page-container {
  padding: 24rpx;
  padding-bottom: 140rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 顶部客户信息 */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, var(--primary, #00a8cc), #0077b6);
  border-radius: var(--radius-lg, 20rpx);
  padding: 48rpx 24rpx 32rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.profile-phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
}

.profile-tags {
  display: flex;
  gap: 12rpx;
}

/* 余额卡片 */
.balance-card {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 32rpx 24rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
}

.balance-label {
  font-size: 24rpx;
  color: var(--text-hint, #999);
  margin-bottom: 12rpx;
}

.balance-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary, #00a8cc);
  font-family: 'Courier New', monospace;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.action-row > t-button {
  flex: 1;
  min-width: calc(50% - 8rpx);
}

/* 通用卡片 */
.card {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.04));
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: var(--text-secondary, #666);
}

.info-value {
  color: var(--text-primary, #333);
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}
