<t-loading wx:if="{{loading}}" loading theme="circular" style="margin-top: 200rpx;" />
<block wx:if="{{!loading && customer}}">
  <!-- 客户基本信息 -->
  <view class="info-card">
    <view class="customer-name-row">
      <text class="customer-name">{{customer.displayName}}</text>
      <t-tag wx:if="{{customer.isMember}}" theme="warning" variant="light">{{customer.memberLevelName}}</t-tag>
    </view>
    <view class="type-badge">
      <t-tag size="small" variant="light" theme="{{customer.customerType === 2 ? 'primary' : customer.customerType === 3 ? 'warning' : 'default'}}">{{customer.typeLabel}}</t-tag>
    </view>
    <view class="info-row" wx:if="{{customer.phone}}">
      <text class="label">电话</text>
      <view class="value-row" bindtap="callPhone">
        <text class="value link">{{customer.phone}}</text>
        <t-icon name="call" size="24rpx" color="#0052D9" />
      </view>
    </view>
    <view class="info-row" wx:if="{{customer.address}}">
      <text class="label">地址</text>
      <text class="value">{{customer.address}}</text>
    </view>
    <view class="info-row" wx:if="{{customer.contactPerson}}">
      <text class="label">联系人</text>
      <text class="value">{{customer.contactPerson}}</text>
    </view>
    <view class="info-row">
      <text class="label">创建时间</text>
      <text class="value time">{{customer.createTime}}</text>
    </view>
  </view>

  <!-- Tab切换 -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange">
    <t-tab-panel label="会员信息" value="info" />
    <t-tab-panel label="历史订单" value="orders" />
  </t-tabs>

  <!-- 会员信息 -->
  <view wx:if="{{activeTab === 'info'}}">
    <view class="card" wx:if="{{customer.isMember}}">
      <view class="member-stats">
        <view class="member-stat">
          <text class="stat-val">¥{{customer.balance}}</text>
          <text class="stat-lbl">当前余额</text>
        </view>
        <view class="member-stat">
          <text class="stat-val">¥{{customer.totalRecharge}}</text>
          <text class="stat-lbl">累计充值</text>
        </view>
        <view class="member-stat">
          <text class="stat-val">¥{{customer.totalConsume}}</text>
          <text class="stat-lbl">累计消费</text>
        </view>
      </view>
      <view class="action-row">
        <t-button theme="primary" size="medium" bindtap="recharge">充值</t-button>
        <t-button variant="outline" size="medium" bindtap="goTransactions">交易记录</t-button>
      </view>
    </view>

    <view class="action-area safe-bottom">
      <t-button wx:if="{{customer.isMember}}" variant="outline" block size="large" bindtap="editCustomer">编辑客户信息</t-button>
      <view wx:else class="two-btns">
        <t-button theme="primary" block size="large" bindtap="upgradeMember">升级为会员</t-button>
        <t-button variant="outline" block size="large" bindtap="editCustomer">编辑</t-button>
      </view>
    </view>
  </view>

  <!-- 历史订单 -->
  <view wx:if="{{activeTab === 'orders'}}" class="order-section">
    <view wx:if="{{ordersLoading}}" style="text-align:center;padding:80rpx 0">
      <t-loading loading theme="circular" size="40rpx" />
    </view>
    <view wx:elif="{{orders.length === 0}}" class="empty-tip">暂无相关订单</view>
    <view class="order-item" wx:for="{{orders}}" wx:key="id" bindtap="goOrderDetail" data-id="{{item.id}}">
      <view class="oi-header">
        <text class="oi-no">{{item.orderNo}}</text>
        <t-tag theme="{{item.statusColor}}" size="small" variant="light">{{item.statusText}}</t-tag>
      </view>
      <view class="oi-body">
        <text class="oi-title">{{item.title || '订单'}}</text>
        <text class="oi-amount">¥{{item.totalAmount}}</text>
      </view>
      <view class="oi-footer">
        <text class="oi-time">{{item.createTime}}</text>
      </view>
    </view>
  </view>
</block>
