<view class="page-container">

  <!-- 顶部客户信息卡片 -->
  <view class="profile-card">
    <view class="profile-avatar">{{displayName[0] || '?'}}</view>
    <text class="profile-name">{{displayName}}</text>
    <text class="profile-phone" wx:if="{{detail.phone}}" bindtap="callPhone">{{detail.phone}}</text>
    <view class="profile-tags">
      <t-tag size="small" variant="light" theme="{{detail.customerType === 2 ? 'primary' : detail.customerType === 3 ? 'warning' : 'default'}}">{{typeName}}</t-tag>
      <t-tag size="small" variant="light" theme="warning" wx:if="{{detail.isMember === 1}}">{{memberLevelName || '会员'}}</t-tag>
    </view>
  </view>

  <!-- 余额卡片 -->
  <view class="balance-card">
    <text class="balance-label">账户余额</text>
    <text class="balance-amount">¥{{balance}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <t-button theme="primary" variant="outline" bindtap="recharge" wx:if="{{detail.isMember === 1}}">
      <t-icon slot="icon" name="add" size="32rpx" />
      充值
    </t-button>
    <t-button theme="primary" variant="outline" bindtap="consume" wx:if="{{detail.isMember === 1}}">
      <t-icon slot="icon" name="remove" size="32rpx" />
      消费
    </t-button>
    <t-button theme="primary" bindtap="upgradeMember" wx:if="{{detail.isMember !== 1}}">
      <t-icon slot="icon" name="usergroup" size="32rpx" />
      升级会员
    </t-button>
    <t-button variant="outline" bindtap="editCustomer">
      <t-icon slot="icon" name="edit" size="32rpx" />
      编辑
    </t-button>
  </view>

  <!-- 详细信息卡片 -->
  <view class="card">
    <view class="section-title">基本信息</view>
    <view class="info-row">
      <text class="info-label">客户名称</text>
      <text class="info-value">{{detail.name || detail.customerName || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{detail.phone || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">客户类型</text>
      <text class="info-value">{{typeName}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.address}}">
      <text class="info-label">地址</text>
      <text class="info-value">{{detail.address}}</text>
    </view>
  </view>
</view>
