.filter-bar {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0 24rpx;
  overflow-x: auto;
}

.filter-tag {
  flex-shrink: 0;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
}

.filter-tag.active {
  background: #0052D9;
  color: #fff;
}

.customer-list {
  padding-bottom: 120rpx;
}

.customer-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.customer-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.customer-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E6F1FB;
  color: #0052D9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.customer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.customer-contact {
  font-size: 24rpx;
  color: #999;
}

.customer-tags {
  display: flex;
  gap: 8rpx;
}

.customer-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

.customer-address {
  font-size: 24rpx;
  color: #bbb;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-balance {
  font-size: 24rpx;
  color: #E6A23C;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.fab-btn {
  position: fixed !important;
  right: 40rpx !important;
  bottom: 180rpx !important;
}
