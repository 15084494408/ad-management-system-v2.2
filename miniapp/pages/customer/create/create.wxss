.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}
.type-options {
  display: flex;
  gap: 16rpx;
}
.type-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.type-option.active {
  border-color: #0052D9;
  color: #0052D9;
  background: #f0f7ff;
  font-weight: 500;
}
.remark-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.submit-area {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
