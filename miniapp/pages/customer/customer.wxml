<view class="page">
  <!-- 顶部搜索 -->
  <t-search value="{{keyword}}" placeholder="搜索客户名称/电话" bind:change="onSearch" bind:submit="doSearch" bind:clear="resetAndLoad" />

  <!-- 筛选标签 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-tag {{activeType === 'all' ? 'active' : ''}}" data-type="all" bindtap="filterType">全部</view>
    <view class="filter-tag {{activeType === 'member' ? 'active' : ''}}" data-type="member" bindtap="filterType">会员</view>
    <view class="filter-tag {{activeType === 'normal' ? 'active' : ''}}" data-type="normal" bindtap="filterType">普通</view>
    <view class="filter-tag {{activeType === 'factory' ? 'active' : ''}}" data-type="factory" bindtap="filterType">工厂</view>
  </scroll-view>

  <!-- 客户列表 -->
  <view class="customer-list">
    <block wx:if="{{loading}}">
      <view class="skeleton-card" wx:for="{{6}}" wx:key="*this" style="margin-bottom:16rpx;height:160rpx"></view>
    </block>

    <block wx:elif="{{customers.length === 0}}">
      <view class="empty-state">暂无客户数据</view>
    </block>

    <block wx:else>
      <view wx:for="{{customers}}" wx:key="id" class="customer-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-main">
          <view class="customer-header">
            <view class="customer-avatar" style="background: {{'#' + Math.floor(item.displayName.charCodeAt(0) * 8421 % 16777215).toString(16).padStart(6, '0')}}">
              {{item.displayName[0] || '?'}}
            </view>
            <view class="customer-info">
              <view class="name-row">
                <text class="customer-name">{{item.displayName}}</text>
                <t-tag size="small" variant="light" theme="{{item.customerType === 2 ? 'primary' : item.customerType === 3 ? 'warning' : 'default'}}">{{item.typeName}}</t-tag>
                <t-tag size="small" variant="light" theme="warning" wx:if="{{item.isMember === 1}}">会员</t-tag>
              </view>
              <text class="customer-phone" wx:if="{{item.phone}}" style="margin-top:4rpx">{{item.phone}}</text>
            </view>
          </view>

          <view class="customer-footer">
            <text class="customer-address" wx:if="{{item.address}}">{{item.address}}</text>
            <text class="customer-address" wx:else>暂无地址</text>
            <text class="customer-balance" wx:if="{{item.balance !== undefined}}">余额: ¥{{item.balance}}</text>
          </view>
        </view>

        <!-- 右侧操作区 -->
        <view class="card-actions">
          <view class="action-btn" data-phone="{{item.phone}}" catchtap="callPhone">
            <t-icon name="phone" size="28rpx" color="#00a8cc" />
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{loadingMore}}" class="load-more">加载中...</view>
  <view wx:elif="{{!loading && customers.length > 0 && noMore}}" class="load-more">没有更多了</view>

  <!-- FAB 新增客户 -->
  <t-fab icon="add" bind:click="addCustomer" />
</view>
