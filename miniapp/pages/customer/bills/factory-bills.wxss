.filter-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.bill-card { cursor: pointer; }
.bill-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.bill-no { font-size: 28rpx; font-weight: 500; color: #333; }
.bill-body { margin-bottom: 8rpx; }
.bill-row { display: flex; justify-content: space-between; padding: 8rpx 0; font-size: 26rpx; }
.bill-label { color: #999; }
.bill-value { color: #333; }
.bill-value.amount { color: #1a1a1a; font-weight: 600; }
.bill-value.paid { color: #0F6E56; }
.bill-footer { padding-top: 12rpx; border-top: 1rpx solid #f5f5f5; }
.bill-time { font-size: 22rpx; color: #bbb; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; gap: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.load-more { text-align: center; padding: 32rpx; font-size: 24rpx; color: #999; }
