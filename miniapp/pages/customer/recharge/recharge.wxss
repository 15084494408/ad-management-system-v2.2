.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}
.balance-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #e6a23c;
}
.method-section {
  margin: 20rpx 0;
}
.method-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.method-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.method-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 26rpx;
  color: #666;
}
.method-btn.active {
  border-color: #0052D9;
  color: #0052D9;
  background: #f0f7ff;
}
.method-icon {
  font-size: 28rpx;
}
.quick-amounts {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.quick-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; display: block; }
.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.quick-btn {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.quick-btn:active, .quick-btn.active {
  background: #E6F1FB;
  color: #0052D9;
}
.submit-area { padding: 24rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
