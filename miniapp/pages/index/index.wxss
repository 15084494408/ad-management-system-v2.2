.page-container {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  position: relative;
}

/* ====== 欢迎卡片 ====== */
.welcome-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, var(--primary, #00a8cc) 0%, #0077b6 100%);
  border-radius: var(--radius-lg, 20rpx);
  padding: 32rpx;
  margin-bottom: 28rpx;
  color: #fff;
  box-shadow: var(--shadow-md, 0 8rpx 24rpx rgba(0, 168, 204, 0.25));
}

.welcome-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.welcome-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.welcome-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.welcome-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.welcome-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.welcome-right {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ====== 骨架屏 ====== */
.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

/* ====== 数据概览 ====== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  background: var(--bg-card, #fff);
  border: 1rpx solid var(--border-color, rgba(0, 0, 0, 0.04));
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0, 0, 0, 0.04));
}

.stat-card-inner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 统计卡片左侧色条 */
.stat-card::after {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 0 3rpx 3rpx 0;
}

.stat-cyan::after { background: var(--primary, #00a8cc); }
.stat-green::after { background: #10b981; }
.stat-orange::after { background: #f59e0b; }
.stat-red::after { background: var(--danger, #ef4444); }

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary, #1a1a2e);
  font-family: 'Courier New', monospace;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint, #999);
}

/* 通知角标 */
.badge-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: var(--danger, #ef4444);
  color: #fff;
  font-size: 20rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  line-height: 1;
}

/* ====== 快捷操作 ====== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a2e);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--primary, #00a8cc);
  border-radius: 3rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--primary, #00a8cc);
}

.quick-actions {
  display: flex;
  justify-content: space-between;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f7fa;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary, #555);
}

/* ====== 更多功能入口 ====== */
.more-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color, #f0f0f0);
}

.more-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary, #666);
  width: calc(25% - 18rpx);
}

.more-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
}

/* ====== 待办概览 ====== */
.todo-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

/* :last-child 在 WXSS 中不支持，底部边框保留 */

.todo-type-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.todo-dot-todo { background: var(--primary, #00a8cc); }
.todo-dot-order { background: #f59e0b; }
.todo-dot-bill { background: #8b5cf6; }

.todo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.todo-text {
  font-size: 28rpx;
  color: var(--text-primary, #333);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-meta {
  font-size: 22rpx;
  color: var(--text-hint, #bbb);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-amount {
  font-size: 26rpx;
  font-weight: 500;
  color: #f59e0b;
  font-family: 'Courier New', monospace;
  flex-shrink: 0;
}

/* ====== 系统公告 ====== */
.notice-card {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0, 0, 0, 0.04));
}

.notice-item-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

/* :last-child 在 WXSS 中不支持，底部边框保留 */

.notice-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(0, 168, 204, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
  min-width: 0;
}

.notice-title {
  font-size: 26rpx;
  color: var(--text-primary, #333);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-time {
  font-size: 22rpx;
  color: var(--text-hint, #bbb);
}

/* ====== 最近订单 ====== */
.order-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color, #f0f0f0);
}

/* :last-child 在 WXSS 中不支持，底部边框保留 */

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-hint, #999);
  font-family: 'Courier New', monospace;
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-customer {
  font-size: 28rpx;
  color: var(--text-secondary, #555);
}

.order-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary, #00a8cc);
  font-family: 'Courier New', monospace;
}

.order-footer {
  display: flex;
  justify-content: space-between;
}

.order-time {
  font-size: 22rpx;
  color: var(--text-hint, #bbb);
}

.order-unpaid {
  font-size: 22rpx;
  color: var(--danger, #ef4444);
  font-weight: 500;
}

/* ====== 通用卡片 ====== */
.card {
  background: var(--bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0, 0, 0, 0.04));
}
