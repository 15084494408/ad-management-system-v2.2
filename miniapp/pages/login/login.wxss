.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-card, #f0f4f8);
  position: relative;
}
.login-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #00a8cc 0%, #0088a8 100%);
  border-radius: 0 0 60rpx 60rpx;
}
.login-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}
.login-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}
.app-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}
.app-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.login-form {
  position: relative;
  z-index: 1;
  margin: 0 40rpx;
  background: #fff;
  border-radius: var(--radius-lg, 24rpx);
  padding: 48rpx 40rpx;
  box-shadow: var(--shadow-md, 0 4rpx 24rpx rgba(0,0,0,0.08));
}
