<view class="login-page">
  <view class="login-bg"></view>
  <view class="login-header">
    <view class="login-logo">广</view>
    <text class="app-title">企业广告管理系统</text>
    <text class="app-subtitle">欢迎登录</text>
  </view>

  <view class="login-form">
    <t-input label="账号" placeholder="请输入用户名" value="{{username}}" bind:change="onFieldChange" data-field="username">
      <t-icon name="user" size="36rpx" color="#999" slot="prefixIcon" />
    </t-input>
    <t-input label="密码" placeholder="请输入密码" type="{{showPassword ? 'text' : 'password'}}" value="{{password}}" bind:change="onFieldChange" data-field="password">
      <t-icon name="lock" size="36rpx" color="#999" slot="prefixIcon" />
      <t-icon slot="suffixIcon" name="{{showPassword ? 'visibility-off' : 'visibility'}}" size="36rpx" color="#999" bindtap="togglePassword" />
    </t-input>

    <view style="display:flex;align-items:center;justify-content:space-between;margin-top:20rpx">
      <t-checkbox checked="{{remember}}" bind:change="onRememberChange">记住密码</t-checkbox>
    </view>

    <t-button theme="primary" block size="large" loading="{{loading}}" bindtap="login" style="margin-top: 40rpx">
      登 录
    </t-button>

    <t-button variant="text" theme="primary" block style="margin-top: 24rpx;" bindtap="wxLogin">
      微信一键登录
    </t-button>

    <text style="display:block;text-align:center;margin-top:48rpx;font-size:22rpx;color:var(--text-hint,#ccc)">v1.0.0</text>
  </view>
</view>
