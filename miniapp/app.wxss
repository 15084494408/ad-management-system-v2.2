/* 全局样式 - TDesign 基础 */
@import 'miniprogram_npm/tdesign-miniprogram/common/style/index.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC',
    'Microsoft YaHei', 'Source Han Sans SC', 'Noto Sans CJK SC', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f7fa;
  box-sizing: border-box;
}

/* 通用工具类 */
.page-container {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 安全区域底部 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 搜索框 */
.t-search {
  --td-search-bg-color: #eef0f4;
}

/* 标签栏 */
.t-tabs {
  --td-tab-item-active-color: #667eea;
  --td-tab-item-active-line-color: #667eea;
}

/* 按钮主色 */
.t-button--theme-primary {
  --td-button-primary-bg-color: #667eea;
  --td-button-primary-border-color: #667eea;
}

/* 浮动按钮 */
.t-fab {
  --td-fab-primary-bg-color: #667eea;
}
